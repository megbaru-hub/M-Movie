generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  username      String?       @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          String        @default("USER")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bio           String?
  accounts      Account[]
  comments      Comment[]
  commentLikes  CommentLike[]
  followedBy    Follow[]      @relation("UserFollowedBy")
  following     Follow[]      @relation("UserFollows")
  sessions      Session[]
  shorts        Short[]
  likedShorts   ShortLike[]
  movies        Movie[]
  watchlist     Watchlist[]
  ratings       Rating[]
  movieComments MovieComment[]
  movieReactions MovieReaction[]
  movieCommentReactions MovieCommentReaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Movie {
  id           Int            @id @default(autoincrement())
  title        String
  slug         String         @unique
  originalFile String?
  subtitles    String?
  thumbnail    String?
  youtubeId    String?
  category     String         @default("movie")
  genre        String?
  country      String?
  year         String?
  views        BigInt         @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  episode      Int?
  season       Int?
  uploaderId   String?
  uploader     User?          @relation(fields: [uploaderId], references: [id])
  variants     MovieVariant[]
  seasons      Season[]
  watchlistedBy Watchlist[]
  ratings      Rating[]
  comments     MovieComment[]
  reactions    MovieReaction[]
}

model Rating {
  id        Int      @id @default(autoincrement())
  movieId   Int
  userId    String
  value     Int      // 1-10 (mapped to 5 stars)
  createdAt DateTime @default(now())
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
}

model MovieVariant {
  id      Int    @id @default(autoincrement())
  movieId Int
  file    String
  quality Int
  sizeMb  Float?
  movie   Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, quality])
}

model Season {
  id           Int       @id @default(autoincrement())
  seriesId     Int
  seasonNumber Int
  episodes     Episode[]
  series       Movie     @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id            Int              @id @default(autoincrement())
  seasonId      Int
  episodeNumber Int
  title         String?
  originalFile  String?
  thumbnail     String?
  subtitles     String?
  youtubeId     String?
  createdAt     DateTime         @default(now())
  season        Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  variants      EpisodeVariant[]

  @@unique([seasonId, episodeNumber])
}

model EpisodeVariant {
  id        Int     @id @default(autoincrement())
  episodeId Int
  file      String
  quality   Int
  sizeMb    Float?
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([episodeId, quality])
}

model Short {
  id          Int         @id @default(autoincrement())
  title       String
  slug        String      @unique
  description String?
  videoFile   String
  thumbnail   String?
  views       BigInt      @default(0)
  duration    Int         @default(0)
  channelName String?
  userId      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  comments    Comment[]
  user        User?       @relation(fields: [userId], references: [id])
  likes       ShortLike[]
}

model Comment {
  id        Int           @id @default(autoincrement())
  shortId   Int
  userId    String
  text      String
  gifUrl    String?
  parentId  Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    Comment?      @relation("ReplyTo", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]     @relation("ReplyTo")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  short     Short         @relation(fields: [shortId], references: [id], onDelete: Cascade)
  likes     CommentLike[]
}

model MovieComment {
  id        Int           @id @default(autoincrement())
  movieId   Int
  userId    String
  text      String
  gifUrl    String?
  parentId  Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    MovieComment? @relation("MovieReplyTo", fields: [parentId], references: [id], onDelete: Cascade)
  replies   MovieComment[] @relation("MovieReplyTo")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie         @relation(fields: [movieId], references: [id], onDelete: Cascade)
  reactions MovieCommentReaction[]
}

model MovieReaction {
  id        Int      @id @default(autoincrement())
  movieId   Int
  userId    String
  type      String   // 'LIKE' or 'DISLIKE'
  createdAt DateTime @default(now())
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
}

model MovieCommentReaction {
  id        Int          @id @default(autoincrement())
  commentId Int
  userId    String
  type      String       // 'LIKE' or 'DISLIKE'
  createdAt DateTime     @default(now())
  comment   MovieComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model ShortLike {
  id      Int    @id @default(autoincrement())
  shortId Int
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  short   Short  @relation(fields: [shortId], references: [id], onDelete: Cascade)

  @@unique([shortId, userId])
}

model CommentLike {
  id        Int     @id @default(autoincrement())
  commentId Int
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  following   User     @relation("UserFollowedBy", fields: [followingId], references: [id])
  follower    User     @relation("UserFollows", fields: [followerId], references: [id])

  @@id([followerId, followingId])
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    String
  movieId   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}
